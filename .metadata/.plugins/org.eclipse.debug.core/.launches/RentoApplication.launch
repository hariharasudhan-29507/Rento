    <stringAttribute key="org.eclipse.jdt.launching.VM_ARGUMENTS" value="--module-path &quot;jars/javafx-sdk-21.0.10/lib&quot; --add-modules javafx.controls,javafx.fxml,javafx.graphics,javafx.web --add-opens javafx.graphics/javafx.scene=ALL-UNNAMED --add-opens javafx.base/com.sun.javafx.runtime=ALL-UNNAMED"/>
