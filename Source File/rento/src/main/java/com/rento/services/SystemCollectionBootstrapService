    public static final List<String> REQUIRED_COLLECTIONS = Arrays.asList(
        "users",
        "vehicles",
        "bookings",
        "rentals",
        "payments",
        "notifications",
        "payment_methods",
        "receipts",
        "audit_logs",
        "support_tickets",
        "maintenance_records",
        "vehicle_inspections",
        "discount_campaigns",
        "branches",
        "pricing_rules",
        "payout_records",
        "system_settings"
    );

    public void ensureCollections() {
        MongoDatabase db = MongoDBConnection.getInstance().getDatabase();
        if (db == null) {
            return;
        }

        for (String collectionName : REQUIRED_COLLECTIONS) {
            boolean exists = false;
            for (String existing : db.listCollectionNames()) {
                if (collectionName.equals(existing)) {
                    exists = true;
                    break;
                }
            }
            if (!exists) {
                db.createCollection(collectionName);
            }
        }

