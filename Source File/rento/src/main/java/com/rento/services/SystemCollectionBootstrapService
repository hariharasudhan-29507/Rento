    public Map<String, Long> getCollectionCounts() {
        Map<String, Long> counts = new LinkedHashMap<>();
        MongoDatabase db = MongoDBConnection.getInstance().getDatabase();
        if (db == null) {
            return counts;
        }
        for (String collectionName : REQUIRED_COLLECTIONS) {
            counts.put(collectionName, db.getCollection(collectionName).countDocuments());
        }
        return counts;
    }

    private void seedIfEmpty(MongoDatabase db, String collectionName, Document sample) {
        MongoCollection<Document> collection = db.getCollection(collectionName);
        if (collection.countDocuments() == 0) {
            collection.insertOne(sample);
        }
    }
}
